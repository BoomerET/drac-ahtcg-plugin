          "$VALUE",
          ["CALC", "{{$SELECTED_VALUE}}"]
        ],
        ["SET", "/arkham/servantOfFlameKilled", "$VALUE"],
        ["ACTION_LIST", "Queen of Ash Scenario Early Init Continue 3"]
      ]
    }
