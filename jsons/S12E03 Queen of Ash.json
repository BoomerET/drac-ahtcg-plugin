  "functions": {
    "ARKHAM_SCOURED_CALLBACK": {
      "args": ["$TARGET_PLAYER", "$TARGET_CARD_ID", "$ARGS", "$ACTOR_PLAYER", "$SELECTED_VALUE"],
      "code": [
        ["VALIDATE_PLAYER", "$TARGET_PLAYER", "ARKHAM_SCOURED_CALLBACK.TARGET_PLAYER"],
        ["VALIDATE_NOT_NULL", "$ARGS", "ARKHAM_SCOURED_CALLBACK.ARGS"],
        ["VALIDATE_NOT_EMPTY", "$SELECTED_VALUE", "ARKHAM_SCOURED_CALLBACK.SELECTED_VALUE"],
        [
          "VAR",
          "$VALUE",
          ["CALC", "{{$SELECTED_VALUE}}"]
        ],
        ["SET", "/arkham/scenarioArkhamScouredState", "$VALUE"],
        ["LOGF", "{0}{1} set Arkham Scoured state to {2}.", "$ARGS", "$TARGET_PLAYER", "$VALUE"],
        ["ACTION_LIST", "Queen of Ash Scenario Early Init Continue 1"]
      ]
    },
    "STIRRED_UP_TROUBLE_CALLBACK": {
      "args": ["$TARGET_PLAYER", "$TARGET_CARD_ID", "$ARGS", "$ACTOR_PLAYER", "$SELECTED_VALUE"],
      "code": [
        ["VALIDATE_PLAYER", "$TARGET_PLAYER", "STIRRED_UP_TROUBLE_CALLBACK.TARGET_PLAYER"],
        ["VALIDATE_NOT_NULL", "$ARGS", "STIRRED_UP_TROUBLE_CALLBACK.ARGS"],
        ["VALIDATE_NOT_EMPTY", "$SELECTED_VALUE", "STIRRED_UP_TROUBLE_CALLBACK.SELECTED_VALUE"],
        [
          "VAR",
          "$VALUE",
          ["CALC", "{{$SELECTED_VALUE}}"]
        ],
        ["SET", "/arkham/scenarioStirredUpTroubleState", "$VALUE"],
        ["LOGF", "{0}{1} set Stirred up Trouble state to {2}.", "$ARGS", "$TARGET_PLAYER", "$VALUE"],
        ["ACTION_LIST", "Queen of Ash Scenario Early Init Continue 2"]
      ]
    },
    "SERVANT_OF_FLAME_KILLED_CALLBACK": {
      "args": ["$TARGET_PLAYER", "$TARGET_CARD_ID", "$ARGS", "$ACTOR_PLAYER", "$SELECTED_VALUE"],
      "code": [
        ["VALIDATE_NOT_EMPTY", "$SELECTED_VALUE", "SERVANT_OF_FLAME_KILLED_CALLBACK.SELECTED_VALUE"],
        [
