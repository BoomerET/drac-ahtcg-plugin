      [
        "DEFINE",
        "$INVESTIGATOR_ID",
        ["GET_CARD_ID", "player1Investigator", 0, 0]
      ],
      [
        "COND",
        ["NOT_EQUAL", "$INVESTIGATOR_ID", null],
