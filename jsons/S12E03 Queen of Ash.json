    "Queen of Ash Scenario Init": [
      ["DO_LOAD_CARDS_SCN", "Queen of Ash"],
      ["DO_LOAD_CARDS_SCN", "BoA_Queen of Ash"],
      ["LOAD_CARDS", "Add 2 Cultists to Chaos Bag"],
      ["LOG", "Added 2 Cultist tokens to the chaos bag."],
      [
        "DEFINE",
        "$SERVANT_CARD_ID",
        ["GET_CARD_ID", "sharedNotInPlay", 0, 0]
      ],
      ["SET", "/arkham/servantOfFlameCardId", "$SERVANT_CARD_ID"],
      ["DO_SET_SPAWN_LOCATION", "12182", 45, 43],
      [
        "COND",
        ["EQUAL", "$GAME.arkham.scenarioArkhamScouredState", 1],
        ["ACTION_LIST", "Add 1 Clue to Each Investigator"],
        ["TRUE"],
        ["LOG", "No bonus clues added."]
      ],
      [
        "COND",
        ["EQUAL", "$GAME.arkham.scenarioStirredUpTroubleState", 1],
        ["ACTION_LIST", "Setup Stirred Up Trouble Cultists"],
        ["TRUE"],
        ["LOG", "The investigators did not stir up trouble."]
      ],
      [
        "COND",
        ["EQUAL", "$GAME.arkham.servantOfFlameKilled", 1],
        ["ACTION_LIST", "Remove Servant of Flame"],
        ["TRUE"],
        ["ACTION_LIST", "Keep Servant of Flame Set Aside"]
