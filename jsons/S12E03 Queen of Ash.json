      ["DO_LOAD_CARDS_SCN", "Cultists"],
      ["DO_LOAD_CARDS_SCN", "Reeking Decay"],
      ["DO_LOAD_CARDS_SCN", "Torment"],
      ["DO_SPAWN_MINI_INVESTIGATORS_AT_LOCATION", "Sewer Culvert", 5, 7, 3, 0],
