    "functions": {
        "DO_SCENARIO_ADVANCE_STORY_FINAL": {
            "args": ["$TARGET_PLAYER", "$TARGET_GROUP_ID", "$TOP_CARD_ID", "$LOG_EVENT", "$ACTOR_PLAYER"],
            "code": [
                ["LOG", "Inside Scenario DO_SCENARIO_ADVANCE_STORY_FINAL"],
                ["VAR", "$TOP_CARD", ["GET_CARD_AND_VALIDATE", "$TOP_CARD_ID", "DO_SCENARIO_ADVANCE_STORY_FINAL.TOP_CARD_ID"]],
                ["VAR", "$HANDLED", false],

                ["COND",
                    ["EQUAL", "$TOP_CARD.sides.A.databaseId", "11504"],
                    [
                        ["VAR", "$HIBBS_CARDS", ["FILTER_CARDS", "$CARD", ["EQUAL", "$CARD.sides.A.databaseId", "11504b"]]],
                        ["VAR", "$HIBBS_ID", "$HIBBS_CARDS.[0].id"],

                        ["SET", "/cardById/$HIBBS_ID/currentSide", "A"],
                        ["MOVE_CARD", "$HIBBS_ID", "sharedLocations", -1],
                        ["SET", "/cardById/$HIBBS_ID/inPlay", true],
                        ["DO_SET_CARD_LOCATION", "$HIBBS_ID", "$CARD_BY_ID.$HIBBS_ID.spawnLeft", "$CARD_BY_ID.$HIBBS_ID.spawnTop"],

                        ["VAR", "$SADIE_CARDS", ["FILTER_CARDS", "$CARD", ["EQUAL", "$CARD.sides.A.databaseId", "11510"]]],
                        ["VAR", "$SADIE_ID", "$SADIE_CARDS.[0].id"],
                        ["MOVE_CARD", "$SADIE_ID", "sharedEncounterDiscard", -1],
                        ["SET", "/cardById/$SADIE_ID/inPlay", true],
                        ["SET", "/cardById/$SADIE_ID/currentSide", "A"],
                        ["ATTACH_CARD", "$SADIE_ID", "$HIBBS_ID"],

                        ["LOG", "└── Hibb's Roadhouse is put into play. Sadie Sheldon spawns at Hibb's Roadhouse."],

                        ["COND",
                            ["GREATER_THAN", ["LENGTH", "$TARGET_GROUP.stackIds"], 1],
                            [
                                ["MOVE_CARD", "$TOP_CARD_ID", "$TARGET_GROUP_ID", -1],
                                ["VAR", "$NEW_TOP_CARD", ["GET_TOP_CARD", "$TARGET_GROUP_ID"]],
                                ["SET", "/cardById/$NEW_TOP_CARD.id/currentSide", "A"]
                            ]
                        ],
                        ["SET", "/cardById/$TOP_CARD_ID/currentSide", "A"],

                        ["UPDATE_VAR", "$HANDLED", true]
                    ],

                    ["EQUAL", "$TOP_CARD.sides.A.databaseId", "11505"],
                    [
                        ["VAR", "$BELLA_CARDS", ["FILTER_CARDS", "$CARD", ["EQUAL", "$CARD.sides.A.databaseId", "11505b"]]],
                        ["VAR", "$BELLA_ID", "$BELLA_CARDS.[0].id"],

                        ["SET", "/cardById/$BELLA_ID/currentSide", "A"],
                        ["MOVE_CARD", "$BELLA_ID", "sharedLocations", -1],
                        ["SET", "/cardById/$BELLA_ID/inPlay", true],
                        ["DO_SET_CARD_LOCATION", "$BELLA_ID", "$CARD_BY_ID.$BELLA_ID.spawnLeft", "$CARD_BY_ID.$BELLA_ID.spawnTop"],

                        ["VAR", "$NAOMI_CARDS", ["FILTER_CARDS", "$CARD", ["EQUAL", "$CARD.sides.A.databaseId", "11511"]]],
                        ["VAR", "$NAOMI_ID", "$NAOMI_CARDS.[0].id"],
                        ["MOVE_CARD", "$NAOMI_ID", "sharedEncounterDiscard", -1],
                        ["SET", "/cardById/$NAOMI_ID/inPlay", true],
                        ["SET", "/cardById/$NAOMI_ID/currentSide", "A"],
                        ["ATTACH_CARD", "$NAOMI_ID", "$BELLA_ID"],

                        ["LOG", "└── La Bella Luna is put into play. Naomi O'Bannion spawns at La Bella Luna."],

                        ["COND",
                            ["GREATER_THAN", ["LENGTH", "$TARGET_GROUP.stackIds"], 1],
                            [
                                ["MOVE_CARD", "$TOP_CARD_ID", "$TARGET_GROUP_ID", -1],
                                ["VAR", "$NEW_TOP_CARD", ["GET_TOP_CARD", "$TARGET_GROUP_ID"]],
                                ["SET", "/cardById/$NEW_TOP_CARD.id/currentSide", "A"]
                            ]
                        ],
                        ["SET", "/cardById/$TOP_CARD_ID/currentSide", "A"],

                        ["UPDATE_VAR", "$HANDLED", true]
                    ]
                ],

                "$HANDLED"
            ]
        }
    }
