{
    "preBuiltDecks": {
        "One Last Job Scenario": {
            "label": "One Last Job",
            "cards": [],
            "postLoadActionList": [
                ["SCENARIO_INIT", "The Drowned City", "The Drowned City", "One Last Job", null, "One Last Job Scenario Init"]
            ]
        },
        "One Last Job": {
            "hideFromSearch": true,
            "label": "One Last Job",
            "cards": [
                {"databaseId": "11501","quantity": 1,"loadGroupId": "sharedScenarioReference"},
                {"databaseId": "11502","quantity": 1,"loadGroupId": "sharedAgendaStory"},//Arkham Nightlife
                {"databaseId": "11503","quantity": 1,"loadGroupId": "sharedAgendaStory"},//Long Night
                {"databaseId": "11509","quantity": 1,"loadGroupId": "sharedLocations","left": "15%","top": "76%"},//Tillinghast Esoterica: Assorted Curiosities
                {"databaseId": "01125","quantity": 1,"loadGroupId": "sharedLocations","left": "55%","top": "76%"},//Rivertown
                {"databaseId": "01129","quantity": 1,"loadGroupId": "sharedLocations","left": "35%","top": "76%"},//Miskatonic University
                {"databaseId": "01132","quantity": 1,"loadGroupId": "sharedLocations","left": "75%","top": "43%"},//Easttown
                {"databaseId": "01134","quantity": 1,"loadGroupId": "sharedLocations","left": "35%","top": "43%"} //Northside
            ]
        }
    },
    "actionLists": {
        "One Last Job Scenario Init": [
            ["SET", "/arkham/advanceStoryOverride", true],
            ["SET", "/arkham/advanceStoryOverrideActionList", "One Last Job Advance Story"],
            ["DO_LOAD_CARDS_SCN","One Last Job"],
            ["DO_LOAD_CARDS_SCN","TDC - One Last Job"],
            ["DO_SET_SPAWN_LOCATION","11504b",75,10],
            ["DO_SET_SPAWN_LOCATION","11505b",55,10],
            ["ACTION_LIST","Random Midnight Mask Downtown"],
            ["ACTION_LIST","Choose Random Act 1a"],
            ["DO_LOAD_CARDS_SCN","TDC - Dreams"],
            ["DO_LOAD_CARDS_SCN","Chilling Cold"],
            ["DO_LOAD_CARDS_SCN","Locked Doors"],
            ["DO_LOAD_CARDS_SCN","Rats"],
            ["DO_LOAD_CARDS_SCN","Striking Fear"],
            ["DO_SPAWN_MINI_INVESTIGATORS_AT_LOCATION", "Tillinghast Esoterica", 5, 7, 3, 0],
            ["SCENARIO_INIT_CONTINUE", null]
        ],
        "Random Midnight Mask Downtown": [
            // Randomize which Downtown to use
            ["VAR", "$MM_DOWNTOWN", ["SHUFFLE_LIST", ["LIST", "01130", "01131"]]],
            ["DO_SPAWN_LOCATION_SCN", "sharedLocations", "$MM_DOWNTOWN.[0]", 55, 43]],
        "Choose Random Act 1a": [
            ["VAR","$FIRST_ACT",["SHUFFLE_LIST",["LIST","11504","11505"]]],
            ["DO_CREATE_STORY_CARD_SCN","Questioning the Gangs","$FIRST_ACT.[0]",1,"sharedActStory"],
            [
                "COND",
                ["EQUAL","$FIRST_ACT.[0]","11504"],
                ["DO_CREATE_STORY_CARD_SCN","The Sheldon Gang","11506",2,"sharedActStory"],
                ["TRUE"],
                ["DO_CREATE_STORY_CARD_SCN","The O'Bannion Gang","11507",2,"sharedActStory"]
            ],
            // Create Act 3
            ["DO_CREATE_STORY_CARD_SCN","Face the Music","11508",3,"sharedActStory"]
        ],
        "One Last Job Advance Story": [
            ["VAR", "$TOP_CARD", ["GET_CARD_AND_VALIDATE", "$GAME.arkham.advanceTopCardId", "One Last Job Advance Story.TOP_CARD_ID"]],
            ["VAR", "$TARGET_GROUP", ["GET_GROUP_AND_VALIDATE", "$GAME.arkham.advanceTargetGroupId", "One Last Job Advance Story.TARGET_GROUP_ID"]],

            ["COND",
                ["EQUAL", "$TOP_CARD.sides.A.databaseId", "11504"],
                [
                    ["SET", "/arkham/advanceHandled", true],
                    ["VAR", "$HIBBS_CARDS", ["FILTER_CARDS", "$CARD", ["EQUAL", "$CARD.sides.A.databaseId", "11504b"]]],
                    ["VAR", "$HIBBS_ID", "$HIBBS_CARDS.[0].id"],
                
                    ["SET", "/cardById/$HIBBS_ID/currentSide", "A"],
                    ["MOVE_CARD", "$HIBBS_ID", "sharedLocations", -1],
                    ["SET", "/cardById/$HIBBS_ID/inPlay", true],
                    ["DO_SET_CARD_LOCATION", "$HIBBS_ID", "$CARD_BY_ID.$HIBBS_ID.spawnLeft", "$CARD_BY_ID.$HIBBS_ID.spawnTop"],
                
                    ["DO_SPAWN_LOCATION_SCN", "sharedLocations", "11510", 78, 79],
                
                    ["LOG", "└── Hibb's Roadhouse is put into play. Sadie Sheldon spawns at Hibb's Roadhouse."],
                
                    ["COND",
                        ["GREATER_THAN", ["LENGTH", "$TARGET_GROUP.stackIds"], 1],
                        [
                            ["MOVE_CARD", "$TOP_CARD.id", "$TARGET_GROUP.id", -1],
                            ["VAR", "$NEW_TOP_CARD", ["GET_TOP_CARD", "$TARGET_GROUP.id"]],
                            ["SET", "/cardById/$NEW_TOP_CARD.id/currentSide", "A"]
                        ]
                    ],
                    ["SET", "/cardById/$TOP_CARD.id/currentSide", "A"]
                ],
            
                ["EQUAL", "$TOP_CARD.sides.A.databaseId", "11505"],
                [
                    ["SET", "/arkham/advanceHandled", true],
                    ["VAR", "$BELLA_CARDS", ["FILTER_CARDS", "$CARD", ["EQUAL", "$CARD.sides.A.databaseId", "11505b"]]],
                    ["VAR", "$BELLA_ID", "$BELLA_CARDS.[0].id"],
                
                    ["SET", "/cardById/$BELLA_ID/currentSide", "A"],
                    ["MOVE_CARD", "$BELLA_ID", "sharedLocations", -1],
                    ["SET", "/cardById/$BELLA_ID/inPlay", true],
                    ["DO_SET_CARD_LOCATION", "$BELLA_ID", "$CARD_BY_ID.$BELLA_ID.spawnLeft", "$CARD_BY_ID.$BELLA_ID.spawnTop"],
                
                    ["DO_SPAWN_LOCATION_SCN", "sharedLocations", "11511", 58, 13],
                
                    ["LOG", "└── La Bella Luna is put into play. Naomi O'Bannion spawns at La Bella Luna."],
                
                    ["COND",
                        ["GREATER_THAN", ["LENGTH", "$TARGET_GROUP.stackIds"], 1],
                        [
                            ["MOVE_CARD", "$TOP_CARD.id", "$TARGET_GROUP.id", -1],
                            ["VAR", "$NEW_TOP_CARD", ["GET_TOP_CARD", "$TARGET_GROUP.id"]],
                            ["SET", "/cardById/$NEW_TOP_CARD.id/currentSide", "A"]
                        ]
                    ],
                    ["SET", "/cardById/$TOP_CARD.id/currentSide", "A"]
                ],
            
                ["TRUE"],
                [
                    ["COND",
                        ["EQUAL", "$TOP_CARD.currentSide", "A"],
                        ["SET", "/cardById/$TOP_CARD.id/currentSide", "B"],
                        ["TRUE"],
                        [
                            ["COND",
                                ["GREATER_THAN", ["LENGTH", "$TARGET_GROUP.stackIds"], 1],
                                ["MOVE_CARD", "$TOP_CARD.id", "$TARGET_GROUP.id", -1]
                            ],
                            ["SET", "/cardById/$TOP_CARD.id/currentSide", "A"]
                        ]
                    ]
                ]
            ]
        ]
    }   
}