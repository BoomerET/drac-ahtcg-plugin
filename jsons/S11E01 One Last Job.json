    "automation": {
        "cards": {
            "11502": { //Arkham Nightlift
                "rules": {
                    "11502b": {
                        "type": "trigger",
                        "priority": 10,
                        "listenTo": ["/cardById/$THIS_ID/currentSide"],
                        "condition": [
                            "AND",
                            ["EQUAL", "/cardById/$THIS_ID/currentSide", "B"],
                            ["EQUAL", "$CARD.currentFace.type", "Act"],
                            ["EQUAL", "$THIS.sides.A.databaseId", "11504"]
                        ],
                        "then": [
                            ["LOG", "Holy Crap, we got here."]
                        ]
                    }
                }
            },
