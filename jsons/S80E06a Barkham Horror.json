              ["ACTION_LIST", "Barkham Horror - Confront the Barfy Cat"], 
              ["EQUAL", "$GAME.arkham.scenarioAnswer1", "B"],
              ["ACTION_LIST", "Barkham Horror - Follow the Cat"],
              ["EQUAL", "$GAME.arkham.scenarioAnswer1", "C"], 
              ["ACTION_LIST", "Barkham Horror - Food"], 
              ["EQUAL", "$GAME.arkham.scenarioAnswer1", "D"],
              ["ACTION_LIST", "Barkham Horror - Investigate the Order"] 
