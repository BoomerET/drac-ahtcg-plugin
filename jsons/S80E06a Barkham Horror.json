            ["VAR", "$VELMAS_DOGHOUSE", ["GET_NAMED_CARD_ID", "zbh_00036"]],
            ["SET", "/cardById/$VELMAS_DOGHOUSE/currentSide", "B"],

            ["ACTION_LIST", "Barkham Horror Scenario - Where to Start"],
            ["VAR", "$MEOWSK_ENEMIES", ["SHUFFLE_LIST", ["LIST", "zbh_00038", "zbh_00039", "zbh_00040", "zbh_00041", "zbh_00042", "zbh_00043", "zbh_00044"]]],
            
            // Remove 1 from the game
            ["DO_CREATE_CARDS_SCN", "Meowsk Enemy", "$MEOWSK_ENEMIES.[6]", 1, "sharedRemoved"],

            // Barkham Asylum
            ["DO_SPAWN_ATTACHED_FACEDOWN_TO_LOCATION_SCN", "Meowsk Enemy", "$MEOWSK_ENEMIES.[0]", "$BARKHAM_ASYLUM"],
            
            // Barkham City Pound
            ["DO_SPAWN_ATTACHED_FACEDOWN_TO_LOCATION_SCN", "Meowsk Enemy", "$MEOWSK_ENEMIES.[1]", "$BARKHAM_CITY_POUND"],

