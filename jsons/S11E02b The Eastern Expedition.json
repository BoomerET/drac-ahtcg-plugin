            ["VAR", "$OPEN_SKY_1", ["GET_TOP_CARD_ID", "sharedPileA"]],
            ["DO_PUT_INTO_PLAY_AT_SCN", "$OPEN_SKY_1", 35, 76],
            ["SET", "/cardById/$OPEN_SKY_1/currentSide", "B"],
            ["VAR", "$OPEN_SKY_2", ["GET_TOP_CARD_ID", "sharedPileA"]],
            ["DO_PUT_INTO_PLAY_AT_SCN", "$OPEN_SKY_2", 15, 43],
            ["SET", "/cardById/$OPEN_SKY_2/currentSide", "B"],
            ["VAR", "$OPEN_SKY_3", ["GET_TOP_CARD_ID", "sharedPileA"]],
            ["DO_PUT_INTO_PLAY_AT_SCN", "$OPEN_SKY_3", 55, 43],
            ["SET", "/cardById/$OPEN_SKY_3/currentSide", "B"],
            ["VAR", "$OPEN_SKY_4", ["GET_TOP_CARD_ID", "sharedPileA"]],
            ["DO_PUT_INTO_PLAY_AT_SCN", "$OPEN_SKY_4", 35, 10],
            ["SET", "/cardById/$OPEN_SKY_4/currentSide", "B"],

            // Get bottom cards from Summit deck
           

            ["VAR", "$PILE_STACKB", "$GAME.groupById.sharedPileB.stackIds"],
            ["VAR", "$PILE_STACKB", ["SHUFFLE_LIST", "$PILE_STACKB"]],
            ["SET", "/groupById/sharedPileB/stackIds", "$PILE_STACKB"],

            ["DO_PLACE_BOTTOM_CARD_FROM_DECK_SCN", "sharedPileB", 55, 76, "A"],
            ["DO_PLACE_BOTTOM_CARD_FROM_DECK_SCN", "sharedPileB", 75, 76, "A"],
            ["DO_PLACE_BOTTOM_CARD_FROM_DECK_SCN", "sharedPileB", 35, 43, "A"],
            ["DO_PLACE_BOTTOM_CARD_FROM_DECK_SCN", "sharedPileB", 75, 43, "A"],
            ["DO_PLACE_BOTTOM_CARD_FROM_DECK_SCN", "sharedPileB", 15, 10, "A"],
            ["DO_PLACE_BOTTOM_CARD_FROM_DECK_SCN", "sharedPileB", 55, 10, "A"],
            ["DO_PLACE_BOTTOM_CARD_FROM_DECK_SCN", "sharedPileB", 75, 10, "A"],

            ["DO_CREATE_CARDS", "$GAME.firstPlayer", "Summit", "11649", 1, "sharedPileB", false, null],
            ["VAR", "$CARD_ID", "{{$GAME.lastLoadedCardIds.[0]}}"],
            ["VAR", "$CARD_STACK_ID", "{{$GAME.cardById.$CARD_ID.stackId}}"],

            ["VAR", "$PILE_STACKS", "$GAME.groupById.sharedPileB.stackIds"],
            ["UPDATE_VAR", "$PILE_STACKS", ["REMOVE_FROM_LIST_BY_VALUE", "$PILE_STACKS", "$CARD_STACK_ID"]],

            ["VAR", "$TOP_PACKET", ["SHUFFLE_LIST", ["LIST", "$CARD_STACK_ID", "$PILE_STACKS.[0]", "$PILE_STACKS.[1]"]]],

            ["VAR", "$REST", ["LIST",
                "$PILE_STACKS.[2]",
                "$PILE_STACKS.[3]",
                "$PILE_STACKS.[4]",
                "$PILE_STACKS.[5]",
                "$PILE_STACKS.[6]"
            ]],
            ["VAR", "$NEW_STACKS", ["CONCAT_LISTS", "$TOP_PACKET", "$REST"]],
            ["SET", "/groupById/sharedPileB/stackIds", "$NEW_STACKS"],





            ["DO_SPAWN_MINI_INVESTIGATORS_AT_LOCATION","R'lyeh Streets", 5, 7, 3, 0],

