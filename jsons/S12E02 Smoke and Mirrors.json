  "actionLists": {
    "Smoke and Mirrors Scenario Early Init": [
      ["ASK_SCENARIO_QUESTION_AND_CONTINUE", "Check Campaign Log.", ["LIST", "Miskatonic University burned.", "The above is NOT true."], "Smoke and Mirrors Scenario Init"]
    ],
    "Smoke and Mirrors Scenario Init": [
      ["DO_LOAD_CARDS_SCN", "Smoke and Mirrors"],
      //["LOAD_CARDS", "Add 2 Cultists to Chaos Bag"],
      ["DO_ADD_CHAOS_TOKENS_SCN", "chaos_cultist", 2],
      ["VAR", "$DOWNTOWN", ["SHUFFLE_LIST", ["LIST", "12145", "12146"]]],
      ["DO_SPAWN_LOCATION_SCN", "sharedLocations", "$DOWNTOWN.[0]",45, 10],
      ["DO_CREATE_CARDS_SCN", "Set Aside", "$DOWNTOWN.[1]", 1, "sharedRemoved"],
      ["VAR", "$UPTOWN", ["SHUFFLE_LIST", ["LIST", "12147", "12148"]]],
      ["DO_SPAWN_LOCATION_SCN", "sharedLocations", "$UPTOWN.[0]", 20, 76],
      ["DO_CREATE_CARDS_SCN", "Set Aside", "$UPTOWN.[1]", 1, "sharedRemoved"],
      ["VAR", "$ARKPEEPS", ["SHUFFLE_LIST", ["LIST", "12139", "12140", "12141", "12142", "12143", "12144", "12138"]]],
      // This ensures that Harbinger is always last in the list, so that we can move it to Not In Play and spawn the other 6 Arkham Citizens before it.
      ["COND", 
        ["EQUAL", "$ARKPEEPS.[6]", "12138"], [
          ["VAR", "$ARKPEEPS", ["LIST", "$ARKPEEPS.[6]", "$ARKPEEPS.[1]", "$ARKPEEPS.[2]", "$ARKPEEPS.[3]", "$ARKPEEPS.[4]", "$ARKPEEPS.[5]", "$ARKPEEPS.[0]"]]
        ]
      ],
      //Move Harbinger to Not In Play
      ["DO_CREATE_CARDS_SCN", "Harbinger", "$ARKPEEPS.[6]", 1, "sharedNotInPlay"],
      ["ACTION_LIST", "Smoke and Mirrors Scenario University Status"],
      ["ACTION_LIST", "Smoke and Mirrors - Attach Hidden Card to Northside"],
      ["ACTION_LIST", "Smoke and Mirrors - Attach Hidden Card to Downtown"],
      ["ACTION_LIST", "Smoke and Mirrors - Attach Hidden Card to Southside"],
      ["ACTION_LIST", "Smoke and Mirrors - Attach Hidden Card to French Hill"],
      ["ACTION_LIST", "Smoke and Mirrors - Attach Hidden Card to Uptown"],
      ["ACTION_LIST", "Smoke and Mirrors - Attach Hidden Card to Waterfront District"],
      ["DO_LOAD_CARDS_SCN", "BoA_Bad Weather"],
      ["DO_LOAD_CARDS_SCN", "BoA_Gangs of Arkham"],
      ["DO_LOAD_CARDS_SCN", "BoA_Arcane Lock"],
      ["DO_LOAD_CARDS_SCN", "BoA_Dead Ends"],
      ["DO_LOAD_CARDS_SCN", "BoA_Flying Terrors"],
      ["DO_LOAD_CARDS_SCN", "BoA_Whippoorwills"],
      ["DO_SPAWN_MINI_INVESTIGATORS_AT_LOCATION", "Miskatonic University", 5, 7, 3, 0],
      ["DO_PLACE_DOOM_ON_CURRENT_AGENDA_SCN", "$GAME.arkham.numPlayers"],

      ["SCENARIO_INIT_CONTINUE", null]
    ],
    "Smoke and Mirrors Scenario University Status": [
      ["COND", ["EQUAL", "$GAME.arkham.scenarioAnswer1", "A"], ["ACTION_LIST", "Smoke and Mirrors - Miskatonic In Flames"], ["TRUE"], ["ACTION_LIST", "Smoke and Mirrors - Miskatonic Quiet"] ]
    ],
    "Smoke and Mirrors - Attach Hidden Card to Northside": [
      ["VAR", "$NORTHSIDE", ["GET_NAMED_CARD_ID", "12149"]],
      ["DO_SPAWN_ATTACHED_FACEDOWN_TO_LOCATION_SCN", "Arkham Citizen", "$ARKPEEPS.[0]", "$NORTHSIDE"]
    ],
    "Smoke and Mirrors - Attach Hidden Card to Downtown": [
      ["DO_SPAWN_ATTACHED_FACEDOWN_TO_LOCATION_SCN", "Arkham Citizen", "$ARKPEEPS.[1]", "$DOWNTOWN.[0]"]
    ],
    "Smoke and Mirrors - Attach Hidden Card to Southside": [
      ["VAR", "$SOUTHSIDE", ["GET_NAMED_CARD_ID", "12153"]],
      ["DO_SPAWN_ATTACHED_FACEDOWN_TO_LOCATION_SCN", "Arkham Citizen", "$ARKPEEPS.[2]", "$SOUTHSIDE"]
    ],
    "Smoke and Mirrors - Attach Hidden Card to French Hill": [
      ["VAR", "$FRENCH_HILL", ["GET_NAMED_CARD_ID", "12154"]],
      ["DO_SPAWN_ATTACHED_FACEDOWN_TO_LOCATION_SCN", "Arkham Citizen", "$ARKPEEPS.[3]", "$FRENCH_HILL"]
    ],
    "Smoke and Mirrors - Attach Hidden Card to Uptown": [
      ["DO_SPAWN_ATTACHED_FACEDOWN_TO_LOCATION_SCN", "Arkham Citizen", "$ARKPEEPS.[4]", "$UPTOWN.[0]"]
    ],
    "Smoke and Mirrors - Attach Hidden Card to Waterfront District": [
      ["VAR", "$WATERFRONT", ["GET_NAMED_CARD_ID", "12152"]],
      ["DO_SPAWN_ATTACHED_FACEDOWN_TO_LOCATION_SCN", "Arkham Citizen", "$ARKPEEPS.[5]", "$WATERFRONT"]
      //["DO_CREATE_CARDS_SCN", "Arkham Citizen", "$ARKPEEPS.[5]", 1, "sharedNotInPlay"],
      //["VAR", "$ENEMY_ID", "$GAME.lastLoadedCardIds.[0]"],
      //["DO_PUT_INTO_PLAY_AT_SCN", "$ENEMY_ID", 73, 46],
      //["DO_FLIP_FACEDOWN", "$GAME.firstPlayer", "$ENEMY_ID", false, null]
    ],
    "Smoke and Mirrors - Miskatonic In Flames": [
      ["DO_SPAWN_LOCATION_SCN", "Miskatonic University In Flames", "12155", 20, 43],
      ["DO_CREATE_CARDS_SCN", "Set Aside", "12156", 1, "sharedRemoved"],
      ["VAR", "$MU_BURNING_ID", ["GET_NAMED_CARD_ID", "12155"]],
      ["SET", "/cardById/$MU_BURNING_ID/currentSide", "A"]
    ],
    "Smoke and Mirrors - Miskatonic Quiet": [
      ["DO_SPAWN_LOCATION_SCN", "Miskatonic University Quiet", "12156", 20, 43],
      ["DO_CREATE_CARDS_SCN", "Set Aside", "12155", 1, "sharedRemoved"],
      ["DO_PLACE_DOOM_ON_CURRENT_AGENDA_SCN", 1],
      ["VAR", "$MU_QUIET_ID", ["GET_NAMED_CARD_ID", "12156"]],
      ["SET", "/cardById/$MU_QUIET_ID/currentSide", "A"]
    ]
  }
}
