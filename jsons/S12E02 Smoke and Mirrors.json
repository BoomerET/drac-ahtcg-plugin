  "functions": {
    "MISKATONIC_STATE_CALLBACK": {
      "args": ["$TARGET_PLAYER", "$TARGET_CARD_ID", "$ARGS", "$ACTOR_PLAYER", "$SELECTED_VALUE"],
      "code": [
        ["VALIDATE_PLAYER", "$TARGET_PLAYER", "MISKATONIC_STATE_CALLBACK.TARGET_PLAYER"],
        ["VALIDATE_NOT_NULL", "$ARGS", "MISKATONIC_STATE_CALLBACK.ARGS"],
        ["VALIDATE_NOT_EMPTY", "$SELECTED_VALUE", "MISKATONIC_STATE_CALLBACK.SELECTED_VALUE"],
        [
          "VAR",
          "$VALUE",
          ["CALC", "{{$SELECTED_VALUE}}"]
        ],
        ["SET", "/arkham/scenarioMiskatonicUniversityState", "$VALUE"],
        ["LOGF", "{0}{1} set Miskatonic University state to {2}.", "$ARGS", "$TARGET_PLAYER", "$VALUE"],
        ["ACTION_LIST", "Smoke and Mirrors Scenario Early Init Continue 1"]
      ]
    }
  }
